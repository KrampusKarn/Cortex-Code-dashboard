# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# ── Secrets / credentials — NEVER commit ─────────────────────────────────────
# This kit connects to Snowflake via the `snow` CLI, which reads credentials
# from ~/.snowflake/connections.toml on the user's machine — NOT from this repo.
# The patterns below are a safety net so keys/connection files can never be
# committed by accident. (If you ever need to commit a *safe* .toml such as a
# pyproject.toml, force-add it: `git add -f pyproject.toml`.)
*.toml
connection.toml
connections.toml
**/connections.toml
*.p8
*.pem
*.key
*.env
.env*
*credentials*
*secret*

# ── Build / temp ─────────────────────────────────────────────────────────────
*.tmp
*.log
output/
dist/
build/

# ── Generated / rendered demo artifacts ──────────────────────────────────────
# These are reproduced byte-for-byte from each example's committed inputs
# (schema_spec.json + kb_content.json) — don't commit the output. Rebuild with:
#   python3 templates/generator/generate_seed.py --spec <spec> --out <ex>/seed --today <date>
#   python3 templates/render.py --spec <spec> --out <ex>
# render.py preserves a hand-authored app/streamlit_app.py (it stays tracked).
examples/*/seed/
examples/*/deploy/
examples/*/app/app_config.py
examples/*/app/snowflake.yml
examples/*/app/_core.py
examples/*/app/rag_chat.py
examples/*/app/environment.yml
