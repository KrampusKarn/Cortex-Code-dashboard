# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# ── Secrets / credentials — NEVER commit ─────────────────────────────────────
# This kit connects to Snowflake via the `snow` CLI, which reads credentials
# from ~/.snowflake/connections.toml on the user's machine — NOT from this repo.
# The patterns below are a safety net so keys/connection files can never be
# committed by accident. (If you ever need to commit a *safe* .toml such as a
# pyproject.toml, force-add it: `git add -f pyproject.toml`.)
*.toml
connection.toml
connections.toml
**/connections.toml
*.p8
*.pem
*.key
*.env
.env*
*credentials*
*secret*

# ── Build / temp ─────────────────────────────────────────────────────────────
*.tmp
*.log
output/
dist/
build/

# ── Generated / rendered demo artifacts ──────────────────────────────────────
# Reproduced from each example's committed inputs (schema_spec.json + kb_content.json)
# by templates/render.py + the generator, so the bulky output stays out of git.
# What IS committed — because the Snowflake Workspace deploy path reads it
# server-side from the repo (no local Python/PUT):
#   • examples/*/app/*                    — for CREATE STREAMLIT FROM @repo
#   • examples/*/deploy/workspace_setup.sql — the one-file "Run All" deploy
# Rebuild the ignored rest with (pin --today for byte-stable output):
#   python3 templates/generator/generate_seed.py --spec <spec> --out <ex>/seed --today <date>
#   python3 templates/render.py --spec <spec> --out <ex> --today <date>
examples/*/seed/
examples/*/deploy/00_bootstrap.sql
examples/*/deploy/01_ddl.sql
examples/*/deploy/04_cortex_search.sql
examples/*/deploy/05_load_seed.sql
examples/*/deploy/run.sh
